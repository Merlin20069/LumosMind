<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/pastel_blue"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PASSIVE ANALYSIS"
                        android:textColor="@color/soft_gray"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/soft_black"
                        android:layout_marginTop="8dp"
                        android:text="Avg: -- mins/day" />

                    <TextView
                        android:id="@+id/tvToday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="16sp"
                        android:textColor="@color/deep_teal"
                        android:text="Today: -- mins" />

                    <TextView
                        android:id="@+id/tvLastUpdated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="11sp"
                        android:textColor="@color/soft_gray"
                        android:text="Last updated: Just now" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Goal Progress Card (New for UI consistency) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily Goal"
                            android:textColor="@color/soft_black"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 hours limit"
                            android:textColor="@color/soft_gray"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp">
                        <ProgressBar
                            android:id="@+id/goalProgress"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="false"
                            android:max="100"
                            android:progress="0"
                            android:progressDrawable="@drawable/circular_progress" />
                        <TextView
                            android:id="@+id/tvProgressPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="@color/soft_black"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:text="0%" />
                    </FrameLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Weekly Overview Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weekly Overview"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/soft_black"
                        android:layout_marginBottom="16dp" />

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/weeklyChart"
                        android:layout_width="match_parent"
                        android:layout_height="240dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Sleep Pattern Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sleep Pattern"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="@color/soft_black" />

                        <TextView
                            android:id="@+id/tvSleepQuality"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/accent_pink"
                            android:background="@drawable/capsule_pink_bg"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp" />

                    </RelativeLayout>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/sleepChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Unlock Stats -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/pastel_yellow"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unlock Statistics"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/soft_black"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvTotalUnlocks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Unlocks (Today): --"
                        android:textColor="@color/soft_black"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvAvgUnlocks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg Unlocks per Day: --"
                        android:textColor="@color/soft_gray"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvNightUnlocks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unlocks at Night: --"
                        android:textColor="@color/soft_black"
                        android:textSize="15sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvAvgNightUnlocks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg Night Unlocks: --"
                        android:textColor="@color/soft_gray"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Call Stats -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/pastel_purple"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Call Statistics"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/soft_black"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvIncomingToday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Incoming: --"
                        android:textColor="@color/soft_black"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvIncomingAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg Incoming per Day: --"
                        android:textColor="@color/soft_gray"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvMissedToday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Missed Calls: --"
                        android:textColor="@color/soft_black"
                        android:textSize="15sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvMissedAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg Missed per Day: --"
                        android:textColor="@color/soft_gray"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvOutgoingToday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Outgoing: --"
                        android:textColor="@color/soft_black"
                        android:textSize="15sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvOutgoingAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg Outgoing per Day: --"
                        android:textColor="@color/soft_gray"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvDurationToday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Call Duration: --"
                        android:textColor="@color/soft_black"
                        android:textSize="15sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvDurationAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg Duration per Day: --"
                        android:textColor="@color/soft_gray"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />

                    <Button
                        android:id="@+id/btnActiveAnalysis"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="View Active Analysis"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        android:backgroundTint="@color/deep_teal"
                        android:textColor="@color/white" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Social Media Sections -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Social Media Usage"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/soft_black"
                android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="80dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today"
                        android:textColor="@color/soft_gray"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:id="@+id/todaySocial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
